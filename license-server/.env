# CourseScribe Licence Server — Environment Variables
# Fill these in before deploying to Railway

# Gumroad webhook secret (get this from your Gumroad product settings)
GUMROAD_WEBHOOK_SECRET=your_gumroad_webhook_secret_here

# Resend API key (get this from resend.com)
RESEND_API_KEY=re_4Ug88NVj_3g2vqFSwDk5Ppg9j88tmXDV4

# The email address licence keys will be sent from
# Must be a domain you've verified in Resend
FROM_EMAIL=noreply@alexhzwoon.cc

# Admin secret for manually issuing keys
# Make this a long random string — keep it private
ADMIN_SECRET=We@reF@mily_CourseScribe_2026

# Database path (Railway persists this automatically)
DB_PATH=licences.db

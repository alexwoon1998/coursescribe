{
  "manifest_version": 3,
  "name": "CourseScribe",
  "version": "1.0.0",
  "description": "Automatically extract and save Coursera video transcripts as DOCX, PDF, or TXT files.",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://www.coursera.org/*",
    "https://coursescribe-production.up.railway.app/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://www.coursera.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["jszip.min.js", "docx.min.js", "html2pdf.min.js", "pdfobject.min.js"],
      "matches": ["https://www.coursera.org/*"]
    }
  ]
}
